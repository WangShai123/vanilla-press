{
  "textMinify.suffix": "min",
  "textMinify.dropConsole": false,
  "textMinify.fileExtensions": {
    "css": false,
    "js": false,
    "json": false,
  },
   "jsMinifyObfuscator.enableAutoSave": false,
   "jsMinifyObfuscator.enableMinify": false,
   "jsMinifyObfuscator.minifySuffix": ".min",
   "jsMinifyObfuscator.enableObfuscator": false,
  "jsMinifyObfuscator.enableTsNoCheck": false,
  "jsMinifyObfuscator.obfuscatorLevel": "high",
  "jsMinifyObfuscator.customObfuscatorOptions": {
    "compact": true, // 代码压缩为一行
    "controlFlowFlattening": false, // 核心：关闭控制流平坦化（防止代码变成复杂的 switch-case）
    "deadCodeInjection": false, // 核心：关闭死代码注入（防止代码体积异常膨胀）
    "debugProtection": false, // 关闭调试器保护（防止代码在控制台报错或死循环）
    "stringArray": false, // 关闭字符串数组提取（防止字符串变成乱码，降低运行性能损耗）
    "identifierNamesGenerator": "mangled", // 核心：使用短标识符（如 a, b, c）替换变量名
    "renameGlobals": true, // 允许重命名全局变量
  },
  "jsMinifyObfuscator.minifyTerserOptions": {
    "compress": {
      "drop_console": true, // 移除 console.log 等调试代码
      "drop_debugger": true, // 移除 debugger 语句
    },
    "mangle": {
      "toplevel": true, // 混淆顶层作用域的变量名
    },
  },

  "npm.scriptRunner": "vp",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "oxc.fmt.configPath": "./vite.config.ts",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  }
}