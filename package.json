{
  "name": "vanilla-press",
  "version": "1.0.3",
  "private": false,
  "description": "A lightweight vanilla JavaScript static document generator.",
  "keywords": [
    "docs",
    "document",
    "generator",
    "html",
    "markdown-it",
    "md",
    "static",
    "vanilla"
  ],
  "homepage": "https://github.com/WangShai123/vanilla-press",
  "bugs": {
    "url": "https://github.com/WangShai123/vanilla-press/issues"
  },
  "license": "ISC",
  "author": "Wang Shai <hiwangshai@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WangShai123/vanilla-press.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node src/build.js",
    "dev": "nodemon --watch src --watch docs --ext js,md,css --ignore dist --ignore output src/build.js"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "glob": "^13.0.6",
    "jsdom": "^29.1.1",
    "markdown-it": "^14.3.0",
    "vanilla-jui": "^1.3.6",
    "vanilla-signal-i18n": "^1.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "nodemon": "^3.1.14",
    "typescript": "~6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "4.1.9"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "11.16.0",
      "onFail": "download"
    }
  },
  "file": [
    ".vite-hooks",
    "docs",
    "src",
    "vite.config.ts"
  ],
  "registry": {
    "type": "git",
    "url": "git+https://github.com/WangShai123/vanilla-press.git"
  }
}
