{
  "name": "create-vanilla-press",
  "version": "1.2.1",
  "private": false,
  "description": "Create a vanilla-press documentation project.",
  "keywords": [
    "docs",
    "document",
    "generator",
    "html",
    "markdown-it",
    "md",
    "static",
    "vanilla"
  ],
  "homepage": "https://github.com/WangShai123/vanilla-press",
  "bugs": {
    "url": "https://github.com/WangShai123/vanilla-press/issues"
  },
  "license": "ISC",
  "author": "Wang Shai <hiwangshai@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WangShai123/vanilla-press.git"
  },
  "bin": {
    "create-vanilla-press": "bin/create.js"
  },
  "files": [
    "bin",
    "docs",
    "README.md",
    "README_zh.md",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": "./src/build.js",
    "./scaffold": "./bin/scaffold.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node src/build.js",
    "dev": "nodemon --watch src --watch docs --ext js,md,css --ignore dist --ignore output src/build.js"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "glob": "^13.0.6",
    "jsdom": "^29.1.1",
    "markdown-it": "^14.3.0",
    "markdown-it-front-matter": "^0.2.4",
    "vanilla-jui": "^1.3.11",
    "vanilla-signal-i18n": "^1.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "nodemon": "^3.1.14",
    "vite": "8.1.5",
    "vite-plus": "^0.2.5"
  },
  "registry": {
    "type": "git",
    "url": "git+https://github.com/WangShai123/vanilla-press.git"
  }
}
